{
  "name": "pinpoint",
  "version": "1.0.0",
  "description": "AI-powered chat application with multiple provider support",
  "main": "dist/server.js",
  "scripts": {
    "build:server": "tsc",
    "build:client": "vite build",
    "build": "npm run build:server && npm run build:client",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "dev:client": "vite --config vite.config.ts",
    "test": "jest"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tsconfig/svelte": "^5.0.8",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jest": "^29.5.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "svelte": "^5.55.0",
    "svelte-check": "^3.8.6",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^6.4.1"
  }
}
